<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sync talks to the desktop over LAN/Tailscale. No background clipboard
         polling: Android 10+ forbids it, and we never request it (ADR-0004). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- SYNC-2 uses plain HTTP to the desktop over LAN/Tailscale (THREAT_MODEL:
         LAN cleartext is an accepted residual risk; Tailscale recommended).
         Android 9+ blocks cleartext by default, so we must opt in or sync fails. -->
    <application
        android:name=".ClipVaultApp"
        android:label="ClipVault"
        android:allowBackup="false"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:usesCleartextTraffic="true"
        android:supportsRtl="true">

        <!-- Main UI: history, search, pairing, settings -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Share Target: the PRIMARY capture path on Android -->
        <activity
            android:name=".share.ShareReceiverActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <!-- QS Tile foreground trampoline. Android 10+ only exposes clipboard
             data to the focused app (or the default IME), so the TileService
             delegates the explicit tap here and this non-exported activity
             reads only after its window receives focus. -->
        <activity
            android:name=".capture.ClipboardCaptureActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:taskAffinity="" />

        <!-- Quick Settings Tile: save the current clipboard with one tap -->
        <service
            android:name=".tile.SaveClipboardTileService"
            android:exported="true"
            android:icon="@android:drawable/ic_menu_save"
            android:label="Save to ClipVault"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- ClipVault Panel IME (companion knowledge panel, ADR-0004 / ROADMAP_V2 PR3) -->
        <service
            android:name=".ime.ClipVaultPanelImeService"
            android:exported="true"
            android:label="ClipVault 面板"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/ime_panel_config" />
        </service>

        <!-- ClipVault Full Keyboard Lab (ROADMAP_V2 PR4, experimental): basic
             English keyboard + ClipVault toolbar. Enable separately in settings. -->
        <service
            android:name=".ime.ClipVaultFullKeyboardService"
            android:exported="true"
            android:label="ClipVault 键盘(实验)"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/ime_full_config" />
        </service>

        <!-- Periodic sync fallback when the app is not in the foreground -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge"
            xmlns:tools="http://schemas.android.com/tools" />
    </application>
</manifest>
